# Production environment — loaded by `next build` / `next start`.
# Non-secret, public config only. Secrets are set in the hosting dashboard
# (e.g. Vercel project env vars) or in .env.local for a local production build.

# Public base URLs used by lib/public-url.ts (survey links, referral links,
# emails). NEXT_PUBLIC_* vars are inlined at build time.
NEXT_PUBLIC_SITE_URL=https://www.prodigitalitydata.live
NEXT_PUBLIC_PORTAL_URL=https://www.prodigitalitydata.live/portal/login
