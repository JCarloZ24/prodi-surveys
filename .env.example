# ── Supabase ────────────────────────────────────────────────────────────────
# Project URL + keys. The NEXT_PUBLIC_* vars are exposed to the browser.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # server only — never expose

# IMPORTANT: In Supabase → Authentication → Sign In / Providers, turn OFF
# "Confirm email". Email is validated by our own OTP flow (is_email_verified).

# ── SMTP (OTP + transactional email via nodemailer) ─────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=accounts@example.com
SMTP_PASS=your-app-password
SMTP_FROM=accounts@example.com

# ── Public URLs ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_BASE_URL=https://your-domain.example

# ── Super-admin seed (used once by `npm run seed:admin`) ────────────────────
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=change-me-strong-password
SEED_ADMIN_NAME=Super Admin

# NOTE: The legacy custom portal auth vars are no longer used and can be removed:
#   ADMIN_PASSWORD, ENUMERATOR_PASSWORD, STAKEHOLDER_PASSWORD, PORTAL_SESSION_SECRET
