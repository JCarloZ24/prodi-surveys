# Development environment — loaded automatically by `next dev`.
# Non-secret, public config only. Secrets (Supabase keys, SMTP, webhook secrets)
# live in .env.local, which is gitignored and overrides these values.

# Public base URLs used by lib/public-url.ts (survey links, referral links,
# emails). NEXT_PUBLIC_* vars are inlined at build time.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_PORTAL_URL=http://localhost:3000/portal/login
